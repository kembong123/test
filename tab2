<script>
// ===== STATE (localStorage) =====
let balance = Number(localStorage.getItem("balance")||0);
let firstNap = localStorage.getItem("firstNap")!=="false";
let bets = JSON.parse(localStorage.getItem("bets")||"[]");

// ===== INIT =====
function init(){
  let u = getCurrentUser();

  if(u){
    loadUserData();
  }

  updateUI();
  renderBets(); // 👈 thêm dòng này
}


// ===== WALLET =====
function updateBalance(){
  document.getElementById("balance").innerText = balance.toLocaleString();
}
function nap(){
  let t = Number(napTien.value||0);
  if(!t) return alert("Nhập số tiền");
  if(firstNap){ t*=3; firstNap=false; }
  balance+=t;
  updateBalance(); save();
  napModal.style.display="none";
}

// ===== BET =====
function openBet(){betModal.style.display="flex";}
function closeBet(){betModal.style.display="none";}
function addBet(){
  let s = document.getElementById("so").value.trim();
  let loai = document.getElementById("loai").value;
  let tien = Number(document.getElementById("tien").value||0);
  if(!s||!tien) return alert("Nhập đủ thông tin");
  if(balance < tien) return alert("Không đủ tiền");

  balance -= tien;
  let item = {
    so: s,
    loai,
    tien,
    time: Date.now(),
    status: "pending" // 👈 thêm dòng này
  };
  bets.unshift(item);

  updateBalance(); save(); renderBets();
  closeBet();
}

function isAfter1835(){
  let now = new Date();
  let h = now.getHours();
  let m = now.getMinutes();

  return (h > 18) || (h === 18 && m >= 35);
}

function settleAllLose(){
  let changed = false;

  bets.forEach(b=>{
    if(b.status === "pending"){
      b.status = "lose";
      changed = true;
    }
  });

  if(changed){
    save();
    renderBets();
    console.log("Đã settle tất cả vé = thua");
  }
}

function renderBets(){
    let list = document.getElementById("list");
    history.innerHTML="";
  
    // ===== PHẦN ĐẶT VÉ (HIỆN FULL hoặc 3 tùy bạn)
    bets.slice(0,3).forEach(b=>{
      let el=document.createElement("div");
      el.className="bet-item";
      el.innerHTML=`<span>${b.so} (${b.loai})</span><b>${b.tien.toLocaleString()}đ</b>`;
      list.appendChild(el);
    });
  
    // ===== LỊCH SỬ (CHỈ 3 CÁI)
    bets.slice(0,3).forEach(b=>{
      let h=document.createElement("div");
      h.className="bet-item";
  
      let statusText = b.status === "pending" ? "⏳"
                      : b.status === "lose" ? "❌"
                      : "🏆";
  
      h.innerHTML = `
        <span>${statusText} ${b.so}</span>
        <b>${b.tien.toLocaleString()}đ</b>
      `;
  
      history.appendChild(h);
