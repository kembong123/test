// random tên
function randomName(){
  let chars = "abcdefghijklmnopqrstuvwxyz";
  let name = chars[Math.floor(Math.random()*chars.length)].toUpperCase();
  name += "***";
  return name;
}

// random tiền
function randomMoney(){
  let arr = [
    100000,200000,300000,500000,
    1000000,2000000,3000000,5000000,
    10000000
  ];

  let v = arr[Math.floor(Math.random()*arr.length)];
  return v.toLocaleString();
}

// random giờ hôm qua
function getYesterdayDate(){
  let d = new Date();
  d.setDate(d.getDate() - 1);

  let day = String(d.getDate()).padStart(2,'0');
  let month = String(d.getMonth()+1).padStart(2,'0');
  let year = d.getFullYear();

  return `${day}/${month}/${year}`;
}

// tạo 300 data
let feedData = [];

function generateFeedData(){
  let actions = [
    () => `💰 ${randomName()} đã nạp ${randomMoney(100000,5000000)}đ`,
    () => `🎯 ${randomName()} vừa đặt cược`,
    () => `💸 ${randomName()} đã nạp thêm ${randomMoney(200000,3000000)}đ`,
    () => `🏆 ${randomName()} đã trúng ${randomMoney(500000,10000000)}đ (hôm qua ${getYesterdayDate()})`
  ];

  for(let i=0;i<300;i++){
    let action = actions[Math.floor(Math.random()*actions.length)];
    feedData.push(action());
  }
}

generateFeedData();

// hiển thị
function showFeed(){
  let box = document.getElementById("liveFeed");
  if(!box) return;

  let item = document.createElement("div");
  item.className = "feed-item";

  let text = feedData[Math.floor(Math.random()*feedData.length)];
  item.innerText = text;

  box.prepend(item);

  // giữ tối đa 4 cái
  if(box.children.length > 4){
    box.removeChild(box.lastChild);
  }

  // tự mất sau 6s
  setTimeout(()=>{
    item.style.opacity = "0";
    item.style.transform = "translateY(10px)";
    setTimeout(()=> item.remove(), 400);
  },6000);
}
