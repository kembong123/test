let regPassInput = document.getElementById("regPass");
let passHint = document.getElementById("regPassHint");

// 👉 nếu bạn muốn tooltip password nằm dưới input thì bật dòng này
// passHint.classList.add("bottom");

regPassInput.addEventListener("focus", ()=>{
  passHint.classList.add("active");
});

regPassInput.addEventListener("blur", ()=>{
  if(regPassInput.value === ""){
    passHint.classList.remove("active");
  }
});

regPassInput.addEventListener("input", ()=>{
  let val = regPassInput.value;

  // ≥6 ký tự + có chữ + số
  let regex = /^(?=.*[A-Za-z])(?=.*\d)[A-Za-z\d]{6,}$/;

  passHint.classList.remove("error","success");

  if(val.length === 0){
    passHint.classList.add("active");
    passHint.innerText = "≥6 ký tự, nên có chữ + số";
  }
  else if(!regex.test(val)){
    passHint.classList.add("active","error");
    passHint.innerText = "❌ Mật khẩu yếu";
  }else{
    passHint.classList.add("active","success");
    passHint.innerText = "✅ Mật khẩu mạnh";
  }
});

