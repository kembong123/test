let xienType = 2;
let selectedXien = [];

/* render 00-99 */
function renderXien(){
    let box = document.getElementById("xienNumbers");
    box.innerHTML="";
    for(let i=0;i<=99;i++){
        let s=document.createElement("span");
        s.innerText = i.toString().padStart(2,'0');

        s.onclick=()=>{
            if(s.classList.contains("disabled")) return;

            if(s.classList.contains("active")){
                s.classList.remove("active");
                selectedXien = selectedXien.filter(x=>x!=s.innerText);
            }else{
                if(selectedXien.length >= xienType) return;
                s.classList.add("active");
                selectedXien.push(s.innerText);
            }

            updateXienUI();
            calcXien();
        }

        box.appendChild(s);
    }
}
renderXien();

/* subtab xiên */
document.querySelectorAll(".subtab-xien").forEach(tab=>{
    tab.onclick=()=>{
        document.querySelectorAll(".subtab-xien").forEach(t=>t.classList.remove("active"));
        tab.classList.add("active");

        xienType = parseInt(tab.dataset.x);

        // 👉 RESET sạch
        resetXien();

        // ❌ KHÔNG auto nữa
    }
});

/* mode xiên */
document.querySelectorAll(".mode-xien").forEach(m=>{
    m.onclick=()=>{
        document.querySelectorAll(".mode-xien").forEach(x=>x.classList.remove("active"));
        m.classList.add("active");

        let mode = m.dataset.mode;

        document.getElementById("xienInput").style.display = mode=="input"?"block":"none";
        document.getElementById("xienChon").style.display = mode=="chon"?"block":"none";

        // 👉 AUTO chọn khi vào tab chọn số nhanh
        if(mode=="chon"){
            quickPick();
        }
    }
});

/* disable số khi đủ */
function updateXienUI(){
    let nums = document.querySelectorAll("#xienNumbers span");

    if(selectedXien.length >= xienType){
        nums.forEach(n=>{
            if(!n.classList.contains("active")){
                n.classList.add("disabled");
            }
        });
    }else{
        nums.forEach(n=>n.classList.remove("disabled"));
    }
}

/* reset */
function resetXien(){
    selectedXien=[];
    document.querySelectorAll("#xienNumbers span").forEach(n=>{
        n.classList.remove("active","disabled");
    });
    calcXien();
}

/* chọn nhanh */
function quickPick(){
    resetXien();

    let arr = [];
    while(arr.length < xienType){
        let num = Math.floor(Math.random()*100).toString().padStart(2,'0');
        if(!arr.includes(num)) arr.push(num);
    }

    selectedXien = arr;

    document.querySelectorAll("#xienNumbers span").forEach(n=>{
        if(arr.includes(n.innerText)){
            n.classList.add("active");
        }
    });

    updateXienUI();
    calcXien();
}

/* tính tiền */
function calcXien(){
    let count = selectedXien.length === xienType ? 1 : 0;
    let money = count * 1000 * multi;

    document.getElementById("count").innerText = count;
    document.getElementById("money").innerText = money.toLocaleString();
}
