<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Lottery UI</title>

<style>
body{
    margin:0;
    font-family:"Segoe UI",sans-serif;
    background:#f3f5f9;
}

/* HEADER */
.header{
    display:flex;
    justify-content:space-between;
    padding:15px 25px;
    background:#fff;
    border-bottom:1px solid #ddd;
}

.balls span{
    width:42px;height:42px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    border-radius:50%;
    color:#fff;
    font-weight:bold;
    margin:0 5px;
    background:linear-gradient(145deg,#5a9df9,#2d6cdf);
}

/* LAYOUT */
.container{display:flex;padding:20px}
.left{flex:3;margin-right:20px}
.right{flex:1;background:#fff;border-radius:12px;padding:15px}

/* BOX */
.box{background:#fff;border-radius:12px;padding:15px}

/* TABS */
.tabs{display:flex;gap:15px;border-bottom:1px solid #eee;padding-bottom:10px}
.tab{cursor:pointer;padding:8px 14px;border-radius:6px}
.tab.active{background:#e7f0ff;color:#2d6cdf;font-weight:bold}

/* SUB */
.subtabs{margin-top:10px;display:flex;gap:10px}
.subtab{background:#f0f2f6;padding:6px 12px;border-radius:6px;cursor:pointer}
.subtab.active{background:#2d6cdf;color:white}

/* SUBTABS DE */
.subtabs-de{margin-top:10px;display:flex;gap:10px;flex-wrap:wrap}
.subtab-de{background:#f0f2f6;padding:6px 12px;border-radius:6px;cursor:pointer}
.subtab-de.active{background:#2d6cdf;color:white}

/* SUBTABS DAU DUOI */
.subtabs-dd{margin-top:10px;display:flex;gap:10px}
.subtab-dd{background:#f0f2f6;padding:6px 12px;border-radius:6px;cursor:pointer}
.subtab-dd.active{background:#2d6cdf;color:white}

/* MODE */
.mode-tabs{margin-top:10px;display:flex;gap:10px;justify-content:flex-end}
.mode{padding:6px 12px;border-radius:6px;background:#eee;cursor:pointer}
.mode.active{background:#2d6cdf;color:#fff}

.mode-tabs-de{margin-top:10px;display:flex;gap:10px;justify-content:flex-end}
.mode-de{padding:6px 12px;border-radius:6px;background:#eee;cursor:pointer}
.mode-de.active{background:#2d6cdf;color:#fff}

.mode-tabs-dd{margin-top:10px;display:flex;gap:10px;justify-content:flex-end}
.mode-dd{padding:6px 12px;border-radius:6px;background:#eee;cursor:pointer}
.mode-dd.active{background:#2d6cdf;color:#fff}

/* NUMBER */
.row{margin-top:15px}
.label{margin-bottom:5px;color:#555}
.numbers span{
    width:38px;height:38px;border-radius:50%;
    border:1px solid #ccc;
    display:inline-flex;align-items:center;justify-content:center;
    margin:3px;cursor:pointer;background:#fff;
    transition:0.2s;
}
.numbers span:hover{border-color:#2d6cdf}
.numbers span.active{
    background:#2d6cdf;color:#fff;border:none;
    box-shadow:0 3px 8px rgba(0,0,0,0.15);
}

/* ACTION */
.actions{margin-top:5px}
.actions button{
    margin:2px;padding:5px 8px;border:none;border-radius:5px;
    cursor:pointer;background:#e6ebf5;
}
.actions button:hover{background:#2d6cdf;color:#fff}

/* INFO */
.info{margin-top:15px;display:flex;justify-content:space-between;align-items:center}
.badge{background:#e7f0ff;padding:5px 10px;border-radius:6px;color:#2d6cdf;font-weight:bold}

/* BUTTON */
.btn{padding:8px 15px;border:none;border-radius:6px;color:#fff;cursor:pointer}
.blue{background:#2d6cdf}
.orange{background:#ff8c1a}
.gray{background:#ccc;color:#333}

.table{margin-top:15px;border-top:1px solid #eee;padding:20px;text-align:center;color:#888}

.numbers span.disabled{
    opacity:0.3;
    pointer-events:none;
}

.mode-tabs-xien{
    margin-top:10px;
    display:flex;
    gap:10px;
    justify-content:flex-end;
}
/* SUBTAB XIÊN */
.subtab-xien{
    background:#f0f2f6;
    padding:6px 12px;
    border-radius:6px;
    cursor:pointer;
    transition:0.2s;
}
.subtab-xien.active{
    background:#2d6cdf;
    color:#fff;
    font-weight:bold;
}

/* MODE XIÊN */
.mode-xien{
    padding:6px 12px;
    border-radius:6px;
    background:#eee;
    cursor:pointer;
    transition:0.2s;
}
.mode-xien.active{
    background:#2d6cdf;
    color:#fff;
}

/* QUICK BUTTON */
#xienQuick button{
    padding:8px 14px;
    border:none;
    border-radius:6px;
    background:#2d6cdf;
    color:#fff;
    cursor:pointer;
}
#xienQuick button:hover{
    background:#1f57b3;
}
</style>
</head>

