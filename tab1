<script>
let rate = 27000;
let multi = 1;
let type = 2;
let mainTab = "bao"; // bao | xien | de | dd
let deRate = 1000;
let ddRate = 1000;

/* render số */
function render(id){
    let box=document.getElementById(id);
    box.innerHTML="";
    for(let i=0;i<=9;i++){
        let s=document.createElement("span");
        s.innerText=i;
        s.onclick=()=>{s.classList.toggle("active");if(mainTab==="de"){calcDe()}else if(mainTab==="dd"){calcDD()}else{calc()};}
        box.appendChild(s);
    }
}
render ("ngan");
render ("tram");
render("chuc");
render("donvi");
render("de-chuc");
render("de-donvi");
render("dd-chuc");


// gán giá trị cho tab lớn lô - xiên  - đề - đầuđuôi
document.querySelectorAll(".tab").forEach((tab, index)=>{
    tab.onclick = ()=>{

        document.querySelectorAll(".tab").forEach(t=>t.classList.remove("active"));
        tab.classList.add("active");

        // Ẩn tất cả
        document.getElementById("chon").style.display="none";
        document.getElementById("input").style.display="none";
        document.getElementById("xienBox").style.display="none";
        document.getElementById("deBox").style.display="none";
        document.getElementById("ddBox").style.display="none";

        document.querySelector(".subtabs").style.display="none";
        document.querySelector(".subtabs-de").style.display="none";
        document.querySelector(".subtabs-dd").style.display="none";
        document.querySelectorAll(".mode-tabs").forEach(m=>m.style.display="none");
        document.querySelector(".mode-tabs-de").style.display="none";
        document.querySelector(".mode-tabs-dd").style.display="none";

        if(index === 0){
            mainTab = "bao";

            document.getElementById("chon").style.display="block";
            document.querySelector(".subtabs").style.display="flex";
            document.querySelectorAll(".mode-tabs")[0].style.display="flex";
            rate = 27000;
            document.getElementById("rate").innerText = rate.toLocaleString();
            resetAll();
        }

        if(index === 1){
            mainTab = "xien";

            document.getElementById("xienBox").style.display="block";

            // 👉 reset khi vào xiên
            resetXien();
        }

        if(index === 2){
            mainTab = "de";
            document.getElementById("deBox").style.display="block";
            document.querySelector(".subtabs-de").style.display="flex";
            document.querySelector(".mode-tabs-de").style.display="flex";
            document.getElementById("rate").innerText = deRate.toLocaleString();
            resetDe();
        }

        if(index === 3){
            mainTab = "dd";
            document.getElementById("ddBox").style.display="block";
            document.querySelector(".subtabs-dd").style.display="flex";
            document.querySelector(".mode-tabs-dd").style.display="flex";
            document.getElementById("rate").innerText = ddRate.toLocaleString();
            resetDD();
        }
    }
});

function resetXien(){
    selectedXien=[];
    document.querySelectorAll("#xienNumbers span").forEach(n=>{
        n.classList.remove("active","disabled");
    });

    document.getElementById("count").innerText = 0;
    document.getElementById("money").innerText = 0;
}

function resetDe(){
    clearRow("de-chuc");
    clearRow("de-donvi");
    multi = 1;
    document.getElementById("multi").innerText = multi;
    calcDe();
}

function resetDD(){
    clearRow("dd-chuc");
    multi = 1;
    document.getElementById("multi").innerText = multi;
    calcDD();
}

/* tab click bao lô */
document.querySelectorAll(".subtab").forEach(tab=>{
    tab.onclick=()=>{
        document.querySelectorAll(".subtab").forEach(t=>t.classList.remove("active"));
        tab.classList.add("active");

        rate = parseInt(tab.dataset.rate);
        type = parseInt(tab.dataset.type);

        document.getElementById("rate").innerText = rate.toLocaleString();

        // show / hide hàng
        document.getElementById("row-ngan").style.display = "none";
        document.getElementById("row-tram").style.display = "none";

        // theo type
        if(type == 3){
            document.getElementById("row-tram").style.display = "block";
        }
        else if(type == 4){
            document.getElementById("row-tram").style.display = "block";
            document.getElementById("row-ngan").style.display = "block";
        }
        calc();
    }
});

/* tab click đề */
document.querySelectorAll(".subtab-de").forEach(tab=>{
    tab.onclick=()=>{
        document.querySelectorAll(".subtab-de").forEach(t=>t.classList.remove("active"));
        tab.classList.add("active");

        deRate = 1000;
        document.getElementById("rate").innerText = deRate.toLocaleString();
        resetDe();
    }
});

/* tab click đầu đuôi */
document.querySelectorAll(".subtab-dd").forEach(tab=>{
    tab.onclick=()=>{
        document.querySelectorAll(".subtab-dd").forEach(t=>t.classList.remove("active"));
        tab.classList.add("active");

        ddRate = 1000;
        document.getElementById("rate").innerText = ddRate.toLocaleString();
        resetDD();
    }
});

/* mode bao lô */
document.querySelectorAll(".mode").forEach(m=>{
    m.onclick=()=>{
        let modeGroup = m.parentElement;
        modeGroup.querySelectorAll(".mode").forEach(x=>x.classList.remove("active"));
        m.classList.add("active");

        let mode=m.dataset.mode;
        
        if(mode == "chon"){
            document.getElementById("chon").style.display="block";
            document.getElementById("input").style.display="none";
        }
        else if(mode == "input"){
            document.getElementById("chon").style.display="none";
            document.getElementById("input").style.display="block";
        }
    }
});

/* mode đề */
document.querySelectorAll(".mode-de").forEach(m=>{
    m.onclick=()=>{
        let modeGroup = m.parentElement;
        modeGroup.querySelectorAll(".mode-de").forEach(x=>x.classList.remove("active"));
        m.classList.add("active");

        let mode=m.dataset.mode;
        
        if(mode == "chon-de"){
            document.getElementById("chon-de").style.display="block";
            document.getElementById("input-de").style.display="none";
        }
        else if(mode == "input-de"){
            document.getElementById("chon-de").style.display="none";
            document.getElementById("input-de").style.display="block";
        }
    }
});

/* mode đầu đuôi */
document.querySelectorAll(".mode-dd").forEach(m=>{
    m.onclick=()=>{
        let modeGroup = m.parentElement;
        modeGroup.querySelectorAll(".mode-dd").forEach(x=>x.classList.remove("active"));
        m.classList.add("active");

        let mode=m.dataset.mode;
        
        if(mode == "chon-dd"){
            document.getElementById("chon-dd").style.display="block";
            document.getElementById("input-dd").style.display="none";
        }
        else if(mode == "input-dd"){
            document.getElementById("chon-dd").style.display="none";
            document.getElementById("input-dd").style.display="block";
        }
    }
});

/* chọn */
function selectRow(id,type){
    let nums=document.querySelectorAll("#"+id+" span");
    nums.forEach(n=>{
        let v=parseInt(n.innerText);

        if(type=="all") n.classList.add("active");
        if(type=="tai") n.classList.toggle("active",v>=5);
        if(type=="xiu") n.classList.toggle("active",v<5);
        if(type=="le") n.classList.toggle("active",v%2==1);
        if(type=="chan") n.classList.toggle("active",v%2==0);
    });
    
    if(mainTab === "de"){
        calcDe();
    } else if(mainTab === "dd"){
        calcDD();
    } else {
        calc();
    }
}

function clearRow(id){
    document.querySelectorAll("#"+id+" span")
    .forEach(n=>n.classList.remove("active"));
    
    if(mainTab === "de"){
        calcDe();
    } else if(mainTab === "dd"){
        calcDD();
    } else {
        calc();
    }
}

/* tính */
function calc(){
    let c = document.querySelectorAll("#chuc .active").length;
    let d = document.querySelectorAll("#donvi .active").length;

    let t = 1;
    let n = 1;

    if(type >= 3){
        t = document.querySelectorAll("#tram .active").length;
        if(t === 0){ updateZero(); return; }
    }

    if(type >= 4){
        n = document.querySelectorAll("#ngan .active").length;
        if(n === 0){ updateZero(); return; }
    }

    if(c === 0 || d === 0){
        updateZero();
        return;
    }

    let count = c * d * t * n;
    let money = count * rate * multi;

    document.getElementById("count").innerText = count;
    document.getElementById("money").innerText = money.toLocaleString();
}

function calcDe(){
    let c = document.querySelectorAll("#de-chuc .active").length;
    let d = document.querySelectorAll("#de-donvi .active").length;

    if(c === 0 || d === 0){
        updateZero();
        return;
    }

    let count = c * d;
    let money = count * deRate * multi;

    document.getElementById("count").innerText = count;
    document.getElementById("money").innerText = money.toLocaleString();
}

function calcDD(){
    let c = document.querySelectorAll("#dd-chuc .active").length;

    if(c === 0){
        updateZero();
        return;
    }

    let count = c;
    let money = count * ddRate * multi;

    document.getElementById("count").innerText = count;
    document.getElementById("money").innerText = money.toLocaleString();
}

function updateZero(){
    document.getElementById("count").innerText = 0;
    document.getElementById("money").innerText = 0;
}

/* nhân */
function plus(){multi++;update()}
function minus(){if(multi>1)multi--;update()}
function update(){
    document.getElementById("multi").innerText=multi;
    if(mainTab === "de"){
        calcDe();
    } else if(mainTab === "dd"){
        calcDD();
    } else {
        calc();
    }
}

/* reset */
function resetAll(){
    clearRow("ngan");
    clearRow("tram");
    clearRow("chuc");
    clearRow("donvi");
    multi=1;
    update();
}

