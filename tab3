function selectRow(id,type){
  let nums=document.querySelectorAll("#"+id+" span");
  nums.forEach(n=>{
    let v=parseInt(n.innerText);
    if(type=="all") n.classList.add("active");
    if(type=="tai") n.classList.toggle("active",v>=5);
    if(type=="xiu") n.classList.toggle("active",v<5);
    if(type=="le") n.classList.toggle("active",v%2==1);
    if(type=="chan") n.classList.toggle("active",v%2==0);
  });
  if(mainTab === "de") calcDe();
  else if(mainTab === "dd") calcDD();
  else if(mainTab === "3c") calc3C();
  else if(mainTab === "4c") calc4C();
  else calc();
}

function clearRow(id){
  document.querySelectorAll("#"+id+" span").forEach(n=>n.classList.remove("active"));
  if(mainTab === "de") calcDe();
  else if(mainTab === "dd") calcDD();
  else if(mainTab === "3c") calc3C();
  else if(mainTab === "4c") calc4C();
  else calc();
}

// ===== CALCULATIONS =====
function calc(){
  let c = document.querySelectorAll("#chuc .active").length;
  let d = document.querySelectorAll("#donvi .active").length;
  let t = 1, n = 1;
  if(type >= 3){
    t = document.querySelectorAll("#tram .active").length;
    if(t === 0){ updateZero(); return; }
  }
  if(type >= 4){
    n = document.querySelectorAll("#ngan .active").length;
    if(n === 0){ updateZero(); return; }
  }
  if(c === 0 || d === 0){ updateZero(); return; }
  let count = c * d * t * n;
  let money = count * rate * multi;
  document.getElementById("count").innerText = count;
  document.getElementById("money").innerText = money.toLocaleString();
}

function calcDe(){
  let c = document.querySelectorAll("#de-chuc .active").length;
  let d = document.querySelectorAll("#de-donvi .active").length;
  if(c === 0 || d === 0){ updateZero(); return; }
  let count = c * d;
  let money = count * deRate * multi;
  document.getElementById("count").innerText = count;
  document.getElementById("money").innerText = money.toLocaleString();
}

function calcDD(){
  let c = document.querySelectorAll("#dd-chuc .active").length;
  if(c === 0){ updateZero(); return; }
  let count = c;
  let money = count * ddRate * multi;
  document.getElementById("count").innerText = count;
  document.getElementById("money").innerText = money.toLocaleString();
}

function calc3C(){
  let tram = document.querySelectorAll("#3c-tram .active").length;
  let chuc = document.querySelectorAll("#3c-chuc .active").length;
  let donvi = document.querySelectorAll("#3c-donvi .active").length;
  if(tram === 0 || chuc === 0 || donvi === 0){ updateZero(); return; }
  let count = tram * chuc * donvi;
  let money = count * rate3c * multi;
  document.getElementById("count").innerText = count;
  document.getElementById("money").innerText = money.toLocaleString();
}

function calc4C(){
  let ngan = document.querySelectorAll("#4c-ngan .active").length;
  let tram = document.querySelectorAll("#4c-tram .active").length;
  let chuc = document.querySelectorAll("#4c-chuc .active").length;
  let donvi = document.querySelectorAll("#4c-donvi .active").length;
  if(ngan === 0 || tram === 0 || chuc === 0 || donvi === 0){ updateZero(); return; }
  let count = ngan * tram * chuc * donvi;
  let money = count * rate4c * multi;
  document.getElementById("count").innerText = count;
  document.getElementById("money").innerText = money.toLocaleString();
}

function updateZero(){
  document.getElementById("count").innerText = 0;
  document.getElementById("money").innerText = 0;
}

// ===== MULTI =====
function plus(){multi++;update()}
function minus(){if(multi>1)multi--;update()}
function update(){
  document.getElementById("multi").innerText=multi;
  if(mainTab === "de") calcDe();
  else if(mainTab === "dd") calcDD();
  else if(mainTab === "3c") calc3C();
  else if(mainTab === "4c") calc4C();
  else calc();
}

