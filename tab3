// ===== XIÊN =====
function renderXien(){
  let box = document.getElementById("xienNumbers");
  if(!box) return;
  box.innerHTML="";
  for(let i=0;i<=99;i++){
    let s=document.createElement("span");
    s.innerText = i.toString().padStart(2,'0');
    s.onclick=()=>{
      if(s.classList.contains("disabled")) return;
      if(s.classList.contains("active")){
        s.classList.remove("active");
        selectedXien = selectedXien.filter(x=>x!=s.innerText);
      }else{
        if(selectedXien.length >= xienType) return;
        s.classList.add("active");
        selectedXien.push(s.innerText);
      }
      updateXienUI();
      calcXien();
    }
    box.appendChild(s);
  }
}

function updateXienUI(){
  let nums = document.querySelectorAll("#xienNumbers span");
  if(selectedXien.length >= xienType){
    nums.forEach(n=>{
      if(!n.classList.contains("active")) n.classList.add("disabled");
    });
  }else{
    nums.forEach(n=>n.classList.remove("disabled"));
  }
}

function resetXien(){
  selectedXien=[];
  document.querySelectorAll("#xienNumbers span").forEach(n=>{
    n.classList.remove("active","disabled");
  });
  calcXien();
}

function calcXien(){
  let count = selectedXien.length === xienType ? 1 : 0;
  let money = count * 1000 * multi;
  document.getElementById("count").innerText = count;
  document.getElementById("money").innerText = money.toLocaleString();
}

document.querySelectorAll(".subtab-xien").forEach(tab=>{
  tab.onclick=()=>{
    document.querySelectorAll(".subtab-xien").forEach(t=>t.classList.remove("active"));
    tab.classList.add("active");
    xienType = parseInt(tab.dataset.x);
    resetXien();
  }
});

